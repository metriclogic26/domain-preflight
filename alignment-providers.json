{
  "providers": [
    {
      "id": "google_workspace",
      "name": "Google Workspace",
      "spf_includes": ["_spf.google.com", "spf.google.com"],
      "alignment_cnames": [
        {
          "selector": "google",
          "cname_host": "google._domainkey.{domain}",
          "cname_value": "google._domainkey.googlemail.com",
          "required": true,
          "label": "DKIM alignment CNAME"
        }
      ],
      "dashboard_url": "https://admin.google.com/ac/apps/gmail/authenticateemail",
      "dashboard_label": "Google Admin → Apps → Gmail → Authenticate email",
      "instructions": "In Google Admin, go to Apps → Gmail → Authenticate email. Generate a DKIM key and publish the CNAME record shown.",
      "docs_url": "https://support.google.com/a/answer/174124"
    },
    {
      "id": "microsoft_365",
      "name": "Microsoft 365",
      "spf_includes": ["spf.protection.outlook.com", "protection.outlook.com"],
      "alignment_cnames": [
        {
          "selector": "selector1",
          "cname_host": "selector1._domainkey.{domain}",
          "cname_value": "selector1-{domain-hyphen}._domainkey.{tenant}.onmicrosoft.com",
          "required": true,
          "label": "DKIM selector 1"
        },
        {
          "selector": "selector2",
          "cname_host": "selector2._domainkey.{domain}",
          "cname_value": "selector2-{domain-hyphen}._domainkey.{tenant}.onmicrosoft.com",
          "required": true,
          "label": "DKIM selector 2"
        }
      ],
      "dashboard_url": "https://security.microsoft.com/dkimv2",
      "dashboard_label": "Microsoft Defender → Email & collaboration → DKIM",
      "instructions": "Go to Microsoft Defender portal → Email & collaboration → Policies → DKIM. Select your domain and enable DKIM signing. Publish the two CNAME records shown.",
      "docs_url": "https://learn.microsoft.com/en-us/microsoft-365/security/office-365-security/email-authentication-dkim-configure"
    },
    {
      "id": "sendgrid",
      "name": "SendGrid",
      "spf_includes": ["sendgrid.net"],
      "alignment_cnames": [
        {
          "selector": "s1",
          "cname_host": "s1._domainkey.{domain}",
          "cname_value": "s1.domainkey.u{uid}.wl.sendgrid.net",
          "required": true,
          "label": "DKIM CNAME 1"
        },
        {
          "selector": "s2",
          "cname_host": "s2._domainkey.{domain}",
          "cname_value": "s2.domainkey.u{uid}.wl.sendgrid.net",
          "required": true,
          "label": "DKIM CNAME 2"
        }
      ],
      "dashboard_url": "https://app.sendgrid.com/settings/sender_auth",
      "dashboard_label": "SendGrid → Settings → Sender Authentication",
      "instructions": "In SendGrid, go to Settings → Sender Authentication → Authenticate Your Domain. Follow the wizard and publish the CNAME records provided.",
      "docs_url": "https://docs.sendgrid.com/ui/account-and-settings/how-to-set-up-domain-authentication"
    },
    {
      "id": "mailgun",
      "name": "Mailgun",
      "spf_includes": ["mailgun.org"],
      "alignment_cnames": [
        {
          "selector": "pic",
          "cname_host": "pic._domainkey.{domain}",
          "cname_value": "pic.mailgun.org",
          "required": true,
          "label": "DKIM CNAME"
        }
      ],
      "dashboard_url": "https://app.mailgun.com/app/sending/domains",
      "dashboard_label": "Mailgun → Sending → Domains",
      "instructions": "In Mailgun, go to Sending → Domains → Add Domain. Publish the DKIM CNAME record shown.",
      "docs_url": "https://documentation.mailgun.com/en/latest/user_manual.html#verifying-your-domain-1"
    },
    {
      "id": "postmark",
      "name": "Postmark",
      "spf_includes": ["spf.mtasv.net"],
      "alignment_cnames": [
        {
          "selector": "pm",
          "cname_host": "pm._domainkey.{domain}",
